{
  "exp_id": "004_dlv3plus_256",
  "description": "DeepLabV3+ + MNv3-Small-100 at 256x256 (resolution-curve extension: 1024 -> 512 -> 256). Same training recipe as 001/002; only input resolution differs. Tests whether the 512 accuracy gain continues at 256.",
  "data": {
    "data_dir": "MSL_NAVCAM_TRAINING_SET",
    "num_pairs": 16063,
    "split": {
      "train_frac": 0.8,
      "val_frac": 0.2,
      "random_state": 42
    },
    "input_hw": 256
  },
  "model": {
    "arch": "smp.DeepLabV3Plus",
    "encoder_name": "tu-mobilenetv3_small_100",
    "encoder_weights": "imagenet",
    "in_channels": 3,
    "classes": 4
  },
  "training": {
    "loss_type": "ce",
    "loss_summary": "CrossEntropyLoss(ignore_index=255)",
    "focal_gamma": null,
    "optimizer": "Adam",
    "lr": 0.001,
    "batch_size": 8,
    "num_workers": 4,
    "epochs": 10,
    "augmentation": "none",
    "class_weights": "none",
    "resampling": "none"
  }
}