{
  "exp_id": "001_dlv3plus_baseline",
  "description": "ITERATION-2 baseline: DeepLabV3+ + MobileNetV3-Small-100 (2.16M params, space-grade compliant). Plain CE, no aug, no class weights, 10 epochs.",
  "data": {
    "data_dir": "MSL_NAVCAM_TRAINING_SET",
    "num_pairs": 16063,
    "split": {
      "train_frac": 0.8,
      "val_frac": 0.2,
      "random_state": 42
    }
  },
  "model": {
    "arch": "smp.DeepLabV3Plus",
    "encoder_name": "tu-mobilenetv3_small_100",
    "encoder_weights": "imagenet",
    "in_channels": 3,
    "classes": 4
  },
  "training": {
    "loss_type": "ce",
    "loss_summary": "CrossEntropyLoss(ignore_index=255)",
    "focal_gamma": null,
    "optimizer": "Adam",
    "lr": 0.001,
    "batch_size": 8,
    "num_workers": 4,
    "epochs": 10,
    "augmentation": "none",
    "class_weights": "none",
    "resampling": "none"
  }
}